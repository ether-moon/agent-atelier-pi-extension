#!/usr/bin/env python3
"""
build-vrm-prompt — Assembles VRM evidence input from work items and spec data.

Enforces the validation information barrier: the output contains ONLY data
derived from the work items, behavior spec, and verification commands. Builder
summaries, diffs, logs, and implementation explanations are excluded.

Usage:
  build-vrm-prompt [--root <path>]

Reads:
  - .agent-atelier/work-items.json (the target work items)
  - .agent-atelier/loop-state.json (active_candidate_set for branch/commit/WI list)

Collects verify commands from ALL work items in the active candidate set
and produces a single evidence bundle.

Outputs:
  JSON matching plugins/agent-atelier/schema/vrm-evidence-input.schema.json

Exit codes: 0=success, 1=usage/validation, 2=precondition failed, 3=not found
"""

import argparse
import json
import os
import subprocess
import sys


def resolve_root(explicit):
    if explicit:
        return os.path.realpath(explicit)
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"],
            stderr=subprocess.DEVNULL, text=True,
        ).strip()
        return os.path.realpath(out)
    except (FileNotFoundError, subprocess.CalledProcessError):
        return os.path.realpath(os.getcwd())


def load_json(path):
    with open(path, encoding="utf-8") as fh:
        return json.load(fh)


def main():
    parser = argparse.ArgumentParser(prog="build-vrm-prompt")
    parser.add_argument("--wi-id", default=None,
                        help="Work item ID (legacy single-WI mode). "
                             "If omitted, uses all WIs from active_candidate_set.")
    parser.add_argument("--root", default=None, help="Repository root")
    args = parser.parse_args()

    root = resolve_root(args.root)
    state_dir = os.path.join(root, ".agent-atelier")

    # ── Load state ────────────────────────────────────────────────────
    wi_path = os.path.join(state_dir, "work-items.json")
    ls_path = os.path.join(state_dir, "loop-state.json")

    if not os.path.exists(wi_path):
        print(f"work-items.json not found at {wi_path}", file=sys.stderr)
        return 3

    if not os.path.exists(ls_path):
        print(f"loop-state.json not found at {ls_path}", file=sys.stderr)
        return 3

    store = load_json(wi_path)
    loop_state = load_json(ls_path)

    # ── Resolve target WI IDs from active_candidate_set ───────────────
    active_set = loop_state.get("active_candidate_set")
    if not active_set:
        print("No active_candidate_set in loop-state", file=sys.stderr)
        return 2

    if args.wi_id:
        target_ids = [args.wi_id]
    else:
        target_ids = active_set.get("work_item_ids", [])

    if not target_ids:
        print("active_candidate_set has no work_item_ids", file=sys.stderr)
        return 2

    # ── Find all target work items ────────────────────────────────────
    items_by_id = {item["id"]: item for item in store.get("items", [])}
    target_wis = []
    missing = []
    for wi_id in target_ids:
        wi = items_by_id.get(wi_id)
        if wi is None:
            missing.append(wi_id)
        else:
            target_wis.append(wi)

    if missing:
        available = list(items_by_id.keys())
        print(f"Work items {missing} not found. Available: {available}", file=sys.stderr)
        return 3

    # ── Validate preconditions ────────────────────────────────────────
    for wi in target_wis:
        if wi.get("status") != "candidate_validating":
            print(
                f"Work item {wi['id']} is in status '{wi.get('status')}', "
                f"expected 'candidate_validating'",
                file=sys.stderr,
            )
            return 2

        if wi["id"] not in active_set.get("work_item_ids", []):
            print(
                f"Work item {wi['id']} is not in the active candidate set",
                file=sys.stderr,
            )
            return 2

    # ── Assemble VRM evidence input ───────────────────────────────────
    # Collect verify commands, criteria refs, paths from ALL target WIs.
    branch = active_set.get("branch", "")
    commit = active_set.get("commit", "")

    all_criteria_refs = []
    all_files_expected = []
    all_verify_commands = []
    all_constraints = []
    all_non_goals = []
    spec_revision = 1

    for wi in target_wis:
        spec_revision = max(spec_revision, wi.get("behavior_spec_revision", 1))

        for b in wi.get("behaviors", []):
            ref = f"docs/product/behavior-spec.md#{b}"
            if ref not in all_criteria_refs:
                all_criteria_refs.append(ref)
        for a in wi.get("input_artifacts", []):
            if a not in all_criteria_refs:
                all_criteria_refs.append(a)

        for p in wi.get("owned_paths", []):
            if p not in all_files_expected:
                all_files_expected.append(p)

        for v in wi.get("verify", []):
            if v not in all_verify_commands:
                all_verify_commands.append(v)

        for c in wi.get("relevant_constraints", []):
            if c not in all_constraints:
                all_constraints.append(c)

        for ng in wi.get("non_goals", []):
            if ng not in all_non_goals:
                all_non_goals.append(ng)

    if not all_verify_commands:
        wi_ids = [wi["id"] for wi in target_wis]
        print(f"Error: work items {wi_ids} have no verify commands — cannot build VRM input", file=sys.stderr)
        return 2

    output = {
        "candidate_set_id": active_set.get("id"),
        "work_item_ids": target_ids,
        "behavior_spec_revision": spec_revision,
        "target_branch": branch,
        "target_commit": commit,
        "acceptance_criteria_refs": all_criteria_refs if all_criteria_refs else ["docs/product/behavior-spec.md"],
        "files_expected": all_files_expected,
        "verification_commands": all_verify_commands,
        "relevant_constraints": all_constraints,
        "non_goals": all_non_goals,
        "forbidden_context": [
            "builder_summary",
            "builder_diff",
            "builder_log",
            "architect_interpretation",
        ],
    }

    json.dump(output, sys.stdout, indent=2, ensure_ascii=False)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    sys.exit(main() or 0)
