#!/usr/bin/env python3
"""
state-commit — Atomic multi-file writer for orchestration state.

All mutation writes to .agent-atelier/** go through this script
to maintain the single-writer guarantee and cross-file consistency.

Usage:
  echo '<transaction-json>' | state-commit [--root <path>] [--replay]

Transaction format (stdin):
{
  "writes": [
    {"path": ".agent-atelier/work-items.json", "expected_revision": 5, "content": {...}},
    {"path": ".agent-atelier/human-gates/_index.md", "content": "# markdown..."}
  ],
  "deletes": [".agent-atelier/human-gates/open/HDR-001.json"]
}

- expected_revision: if set, current file's .revision must match or the tx is rejected.
  Set to null for new files or non-JSON files.
- content: dict/list → written as JSON; string → written as-is.
- deletes: list of relative paths to remove after writes succeed.

Concurrency: an exclusive flock on .state.lock serializes all commits,
so the validate→write window is race-free even with parallel agents.

--replay: WAL recovery mode. For each write, if the file already contains
  the target revision (partially applied), skip it. Write only the files
  that weren't applied yet, then apply pending deletes. This handles the
  case where a crash happened mid-transaction.

Exit codes: 0=success, 1=usage/invalid transaction, 2=stale revision, 4=runtime error
"""

import datetime
import fcntl
import json
import os
import subprocess
import sys
import tempfile


# ── Verb whitelist (data-plane) ─────────────────────────────────
# Each verb declares its target file, target type, and the exact
# set of fields it may modify.  Any field outside the whitelist
# causes an immediate rejection (exit 1).
VERB_WHITELIST = {
    "heartbeat": {
        "file": ".agent-atelier/work-items.json",
        "target_type": "work_item",
        "fields": frozenset({"last_heartbeat_at", "lease_expires_at"}),
    },
    "record-attempt": {
        "file": ".agent-atelier/work-items.json",
        "target_type": "work_item",
        "fields": frozenset({"attempt_count", "last_attempt_ref", "last_finding_fingerprint"}),
    },
    "record-requeue-meta": {
        "file": ".agent-atelier/work-items.json",
        "target_type": "work_item",
        "fields": frozenset({"stale_requeue_count", "last_requeue_reason"}),
    },
    "watchdog-tick-meta": {
        "file": ".agent-atelier/watchdog-jobs.json",
        "target_type": "store",
        "fields": frozenset({"open_alerts", "last_tick_at"}),
    },
}


def _reject(exit_code, reason, **kwargs):
    """Write a rejection response to stdout and return the exit code."""
    json.dump({"committed": False, "reason": reason, **kwargs}, sys.stdout, indent=2)
    sys.stdout.write("\n")
    return exit_code


def _find_wi_write(writes):
    """Find the work-items.json write in a transaction, or None."""
    for w in writes:
        if w["path"].endswith("work-items.json"):
            return w
    return None


def resolve_root(explicit):
    if explicit:
        return os.path.realpath(explicit)
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"],
            stderr=subprocess.DEVNULL, text=True,
        ).strip()
        return os.path.realpath(out)
    except (FileNotFoundError, subprocess.CalledProcessError):
        return os.path.realpath(os.getcwd())


def orchestration_root(root):
    return os.path.realpath(os.path.join(root, ".agent-atelier"))


def resolve_tx_path(root, candidate):
    if not isinstance(candidate, str) or not candidate:
        raise ValueError(f"transaction path must be a non-empty string: {candidate!r}")

    allowed_root = orchestration_root(root)
    resolved = os.path.realpath(os.path.join(root, candidate))

    try:
        within_root = os.path.commonpath([allowed_root, resolved]) == allowed_root
    except ValueError:
        within_root = False

    if not within_root:
        raise ValueError(
            f"path escapes .agent-atelier boundary: {candidate}"
        )

    return resolved


def atomic_write(path, text):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path), suffix=".tmp")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as fh:
            fh.write(text)
        os.replace(tmp, path)
    except BaseException:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def read_revision(path):
    if not os.path.exists(path):
        return None
    with open(path, encoding="utf-8") as fh:
        return json.load(fh).get("revision")


def content_revision(content):
    if isinstance(content, dict):
        return content.get("revision")
    return None


def serialize(content):
    if isinstance(content, (dict, list)):
        return json.dumps(content, indent=2, ensure_ascii=False) + "\n"
    return str(content)


def _emit_event(root, tx, artifacts):
    """Append a semantic event to events.ndjson after a successful commit.

    The event stream is advisory — if the append fails (disk full, permissions,
    etc.) the error is logged to stderr but does NOT fail the transaction.
    """
    try:
        # Derive the new revision from the committed artifacts: use the highest
        # revision among written files that were actually applied (present in
        # the artifacts list).  During replay, skipped files are excluded so the
        # event revision reflects only what changed in *this* invocation.
        artifact_set = set(artifacts)
        new_revision = None
        for w in tx.get("writes", []):
            if w.get("path") not in artifact_set:
                continue
            rev = content_revision(w.get("content"))
            if rev is not None:
                if new_revision is None or rev > new_revision:
                    new_revision = rev

        # mutations: the file basenames that were actually touched
        mutations = [os.path.basename(a) for a in artifacts]

        # summary: prefer the transaction's message field, fall back to generic
        summary = tx.get("message") or "state committed"

        event = {
            "event": "state_committed",
            "timestamp": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ"),
            "revision": new_revision,
            "request_id": tx.get("request_id"),
            "mutations": mutations,
            "summary": summary,
        }

        events_path = os.path.join(root, ".agent-atelier", "events.ndjson")
        os.makedirs(os.path.dirname(events_path), exist_ok=True)
        with open(events_path, "a", encoding="utf-8") as fh:
            fh.write(json.dumps(event, ensure_ascii=False, separators=(",", ":")) + "\n")
    except Exception as exc:
        print(f"state-commit: event emit failed: {exc}", file=sys.stderr)


def _verb_commit(root, verb_input):
    """Verb mode: data-plane write with field whitelist validation.

    Reads the target file, validates verb+fields against the whitelist,
    applies the patch, bumps revisions, then delegates to _commit for
    WAL-based atomic write.
    """
    if not isinstance(verb_input, dict):
        return _reject(1, "invalid_verb_payload", message="verb transaction must be a JSON object")

    verb = verb_input.get("verb")
    target = verb_input.get("target")
    fields = verb_input.get("fields", {})
    based_on_revision = verb_input.get("based_on_revision")

    if verb not in VERB_WHITELIST:
        return _reject(1, "unknown_verb", verb=verb)

    spec = VERB_WHITELIST[verb]

    if not isinstance(fields, dict):
        return _reject(1, "invalid_verb_payload", message="'fields' must be an object")

    if not isinstance(based_on_revision, int):
        return _reject(1, "invalid_verb_payload", message="'based_on_revision' must be an integer")

    # Validate fields against whitelist
    disallowed = set(fields.keys()) - spec["fields"]
    if disallowed:
        return _reject(1, "field_not_allowed", verb=verb, disallowed_fields=sorted(disallowed))

    if not fields:
        return _reject(1, "no_fields", verb=verb)

    # Read current file
    file_rel = spec["file"]
    file_path = resolve_tx_path(root, file_rel)

    if not os.path.exists(file_path):
        return _reject(1, "target_file_missing", path=file_rel)

    with open(file_path, encoding="utf-8") as fh:
        store = json.load(fh)

    current_revision = store.get("revision")
    if current_revision != based_on_revision:
        return _reject(2, "stale_revision", path=file_rel,
                        expected=based_on_revision, actual=current_revision)

    if spec["target_type"] == "work_item":
        if not target:
            return _reject(1, "missing_target", verb=verb)

        items = store.get("items", [])
        wi_index = None
        for i, item in enumerate(items):
            if item.get("id") == target:
                wi_index = i
                break

        if wi_index is None:
            return _reject(1, "target_not_found", target=target)

        # Apply field patches to WI
        for k, v in fields.items():
            store["items"][wi_index][k] = v

        # Bump WI revision
        store["items"][wi_index]["revision"] = store["items"][wi_index].get("revision", 0) + 1

    elif spec["target_type"] == "store":
        # Apply field patches at store level
        for k, v in fields.items():
            store[k] = v

    # Bump store revision + updated_at
    store["revision"] = (based_on_revision or 0) + 1
    store["updated_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    # Construct transaction and commit through normal path
    tx = {
        "writes": [{
            "path": file_rel,
            "expected_revision": based_on_revision,
            "content": store,
        }],
        "deletes": [],
        "message": f"verb:{verb} target:{target or 'store'}",
    }

    return _commit(root, tx, tx["writes"], tx["deletes"])


def _resolve_dependencies(root, writes):
    """Pre-WAL: auto-transition pending WIs to ready when all deps are done.

    Compares the new state (in the transaction) against the current on-disk
    state to find WIs that are newly transitioning to 'done'.  For each
    'pending' WI whose entire depends_on set is now 'done', mutates its
    status to 'ready' in-place (same transaction).

    Returns list of auto-transitioned WI IDs.
    """
    wi_write = _find_wi_write(writes)
    if wi_write is None:
        return []

    new_content = wi_write["content"]
    if not isinstance(new_content, dict):
        return []

    new_items = new_content.get("items", [])
    if not new_items:
        return []

    # Read old state to identify newly-done WIs
    old_path = resolve_tx_path(root, wi_write["path"])
    old_status = {}
    if os.path.exists(old_path):
        with open(old_path, encoding="utf-8") as fh:
            old_data = json.load(fh)
        for item in old_data.get("items", []):
            old_status[item["id"]] = item.get("status")

    # Check if any WI newly transitioned to done
    newly_done = False
    for item in new_items:
        if item.get("status") == "done" and old_status.get(item["id"]) != "done":
            newly_done = True
            break

    if not newly_done:
        return []

    # Build new status map
    new_status = {item["id"]: item.get("status") for item in new_items}

    # Find pending WIs whose all deps are now done
    transitioned = []
    for item in new_items:
        if item.get("status") != "pending":
            continue
        deps = item.get("depends_on", [])
        if not deps:
            continue
        if all(new_status.get(dep) == "done" for dep in deps):
            item["status"] = "ready"
            item["revision"] = item.get("revision", 0) + 1
            transitioned.append(item["id"])

    return transitioned


def _depends_on_changed(root, writes):
    """Return True when this transaction mutates any WI dependency set."""
    wi_write = _find_wi_write(writes)
    if wi_write is None:
        return False

    content = wi_write["content"]
    if not isinstance(content, dict):
        return False

    new_items = content.get("items", [])
    old_items = {}
    old_path = resolve_tx_path(root, wi_write["path"])
    if os.path.exists(old_path):
        with open(old_path, encoding="utf-8") as fh:
            old_data = json.load(fh)
        old_items = {
            item.get("id"): item.get("depends_on", [])
            for item in old_data.get("items", [])
        }

    for item in new_items:
        wi_id = item.get("id")
        new_deps = item.get("depends_on", [])
        old_deps = old_items.get(wi_id)
        if old_deps is None:
            if new_deps:
                return True
            continue
        if old_deps != new_deps:
            return True

    return False


def _detect_cycles(writes):
    """Check for dependency cycles in work-items.json.

    Returns list of WI IDs forming the cycle, or None if no cycle exists.
    """
    wi_write = _find_wi_write(writes)
    if wi_write is None:
        return None

    content = wi_write["content"]
    if not isinstance(content, dict):
        return None

    items = content.get("items", [])
    if not items:
        return None

    # Build adjacency: WI → its dependencies
    graph = {}
    all_ids = set()
    for item in items:
        wi_id = item.get("id")
        all_ids.add(wi_id)
        deps = item.get("depends_on", [])
        if deps:
            graph[wi_id] = deps

    if not graph:
        return None

    # DFS cycle detection (three-color algorithm)
    WHITE, GRAY, BLACK = 0, 1, 2
    color = {wi_id: WHITE for wi_id in all_ids}
    path = []

    def dfs(node):
        color[node] = GRAY
        path.append(node)
        for dep in graph.get(node, []):
            if dep not in color:
                continue  # dangling ref — not a WI in this store
            if color[dep] == GRAY:
                cycle_start = path.index(dep)
                return path[cycle_start:] + [dep]
            if color[dep] == WHITE:
                result = dfs(dep)
                if result:
                    return result
        path.pop()
        color[node] = BLACK
        return None

    for node in list(all_ids):
        if color[node] == WHITE:
            cycle = dfs(node)
            if cycle:
                return cycle

    return None


def main():
    import argparse
    parser = argparse.ArgumentParser(prog="state-commit")
    parser.add_argument("--root", default=None)
    parser.add_argument("--replay", action="store_true",
                        help="WAL recovery: skip already-applied writes")
    args = parser.parse_args()
    root = resolve_root(args.root)

    tx = None
    writes = []
    deletes = []
    is_verb = False

    if not args.replay:
        try:
            tx = json.load(sys.stdin)
        except json.JSONDecodeError as exc:
            return _reject(1, "invalid_transaction", message=str(exc))

        if not isinstance(tx, dict):
            return _reject(1, "invalid_transaction", message="transaction must be a JSON object")

        is_verb = "verb" in tx
        if not is_verb:
            writes = tx.get("writes", [])
            deletes = tx.get("deletes", [])
            if not isinstance(writes, list) or not isinstance(deletes, list):
                return _reject(1, "invalid_transaction", message="'writes' and 'deletes' must be lists")
            if not writes and not deletes:
                print("Empty transaction", file=sys.stderr)
                return 1
            try:
                for w in writes:
                    resolve_tx_path(root, w["path"])
                for d in deletes:
                    resolve_tx_path(root, d)
            except (KeyError, ValueError) as exc:
                return _reject(1, "invalid_path", message=str(exc))

    # ── Acquire exclusive lock ────────────────────────────────────────
    # flock serializes concurrent agents so the validate→write window
    # is atomic. The lock is released when the fd is closed (including
    # on crash — the OS reclaims it).
    lock_path = os.path.join(root, ".agent-atelier/.state.lock")
    os.makedirs(os.path.dirname(lock_path), exist_ok=True)
    lock_fd = open(lock_path, "w")
    try:
        fcntl.flock(lock_fd.fileno(), fcntl.LOCK_EX)

        if args.replay:
            return _replay(root)
        elif is_verb:
            return _verb_commit(root, tx)
        else:
            return _commit(root, tx, writes, deletes)
    finally:
        fcntl.flock(lock_fd.fileno(), fcntl.LOCK_UN)
        lock_fd.close()


def _commit(root, tx, writes, deletes):
    """Normal commit: validate revisions → WAL → apply writes → apply deletes → cleanup."""

    # Phase 1: validate all revisions before any write
    for w in writes:
        expected = w.get("expected_revision")
        if expected is None:
            continue
        path = resolve_tx_path(root, w["path"])
        current = read_revision(path)
        if current != expected:
            return _reject(2, "stale_revision", path=w["path"],
                            expected=expected, actual=current)

    # Phase 1b: dependency cycle detection
    if _depends_on_changed(root, writes):
        cycle = _detect_cycles(writes)
        if cycle:
            return _reject(1, "dependency_cycle", cycle=cycle)

    # Phase 1c: pre-WAL dependency resolution
    auto_transitioned = _resolve_dependencies(root, writes)
    if auto_transitioned:
        print(f"state-commit: auto-transitioned {auto_transitioned} pending→ready",
              file=sys.stderr)

    # Phase 2: write WAL
    wal_path = os.path.join(root, ".agent-atelier/.pending-tx.json")
    atomic_write(wal_path, json.dumps(tx, indent=2, ensure_ascii=False) + "\n")

    # Phase 3: apply writes
    artifacts = []
    for w in writes:
        path = resolve_tx_path(root, w["path"])
        atomic_write(path, serialize(w["content"]))
        artifacts.append(w["path"])

    # Phase 4: apply deletes
    for d in deletes:
        path = resolve_tx_path(root, d)
        try:
            os.unlink(path)
            artifacts.append(d)
        except FileNotFoundError:
            pass

    # Phase 5: remove WAL
    try:
        os.unlink(wal_path)
    except OSError:
        pass

    json.dump({"committed": True, "artifacts": artifacts}, sys.stdout, indent=2)
    sys.stdout.write("\n")

    # ── Emit semantic event ──────────────────────────────────────────
    # Append a structured NDJSON event to events.ndjson so downstream
    # monitors can react to state changes without polling raw files.
    # This is advisory — failures are logged but do not fail the tx.
    _emit_event(root, tx, artifacts)

    return 0


def _replay(root):
    """WAL replay: complete a partially applied transaction.

    Reads the WAL file (.pending-tx.json) as the source of truth rather
    than trusting stdin, preventing loss of pending recovery state if
    stdin differs from what was originally written to the WAL.

    For each write, compare the file's current revision against the
    target revision in the WAL content:
      - Matches target → already applied, skip.
      - Matches expected (or file missing) → not yet applied, write it.
      - Neither → conflict (another writer intervened), report error.
    """
    wal_path = os.path.join(root, ".agent-atelier/.pending-tx.json")
    if not os.path.exists(wal_path):
        return _reject(4, "wal_missing")

    try:
        with open(wal_path, encoding="utf-8") as fh:
            tx = json.load(fh)
        writes = tx.get("writes", [])
        deletes = tx.get("deletes", [])
        if not isinstance(writes, list) or not isinstance(deletes, list):
            raise ValueError("WAL transaction must contain list fields: writes, deletes")
    except (OSError, json.JSONDecodeError, ValueError) as exc:
        return _reject(4, "wal_invalid", message=str(exc))

    artifacts = []
    skipped = []

    for w in writes:
        path = resolve_tx_path(root, w["path"])
        target_rev = content_revision(w["content"])
        current_rev = read_revision(path) if os.path.exists(path) else None
        expected_rev = w.get("expected_revision")

        if target_rev is not None and current_rev == target_rev:
            skipped.append(w["path"])
            continue

        if expected_rev is not None and current_rev != expected_rev and current_rev != target_rev:
            return _reject(4, "replay_conflict", path=w["path"],
                            expected=expected_rev, target=target_rev, actual=current_rev)

        atomic_write(path, serialize(w["content"]))
        artifacts.append(w["path"])

    for d in deletes:
        path = resolve_tx_path(root, d)
        try:
            os.unlink(path)
            artifacts.append(d)
        except FileNotFoundError:
            skipped.append(d)

    # Remove WAL after successful replay
    try:
        os.unlink(wal_path)
    except OSError:
        pass

    json.dump({
        "committed": True,
        "replayed": True,
        "artifacts": artifacts,
        "skipped": skipped,
    }, sys.stdout, indent=2)
    sys.stdout.write("\n")

    # Emit a state_committed event so downstream monitors see WAL recoveries.
    # Uses the same advisory pattern as _commit — failures are logged, not raised.
    if artifacts:
        _emit_event(root, tx, artifacts)

    return 0


if __name__ == "__main__":
    sys.exit(main() or 0)
